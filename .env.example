BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321

# Bot owner — only this user can /addadmin or /removeadmin.
# Optional: if not set, the FIRST id in ADMIN_IDS above is treated as owner.
OWNER_ID=123456789

# Supabase → Settings → Database → Connection string (Transaction pooler, port 6543)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ── Optional: auto-sync users from your OTHER bots' databases ─────────────────
# Every USER_SYNC_INTERVAL_HOURS the scammer bot pulls (telegram_id, username,
# full_name) from each source DB's `users` table into its bot_users cache — so
# anyone who uses any of your bots becomes resolvable here automatically.
# Comma-separated Postgres URLs. Leave blank to disable.
SOURCE_DATABASE_URLS=
USER_SYNC_INTERVAL_HOURS=6

# ── Optional: web admin panel (audit log of admin actions) ────────────────────
# Shows which admin did what (approve/reject/edit/remove/...) in a browser.
# Disabled unless BOTH a port and a password are set. Use a long random pass —
# Basic auth over plain HTTP is weak; prefer an SSH tunnel or nginx+HTTPS.
WEB_ADMIN_PORT=
WEB_ADMIN_USER=admin
WEB_ADMIN_PASS=

# ── Optional: userbot member-list harvester (userbot/harvester.py) ────────────
# Only needed if you run the userbot to build a bigger id→username directory.
# Get API_ID + API_HASH from https://my.telegram.org (see userbot/README.md).
# Leave blank to disable — the main bot ignores these.
USERBOT_API_ID=
USERBOT_API_HASH=
USERBOT_SESSION=userbot
USERBOT_SCRAPE_INTERVAL_HOURS=12
USERBOT_PER_REQUEST_DELAY=3
